    <Cell><Data ss:Type="String">Год</Data></Cell>
    <Cell><Data ss:Type="String">Eurostat (2015=100)</Data></Cell>
    <Cell><Data ss:Type="String">OECD (2015=100)</Data></Cell>
    <Cell><Data ss:Type="String">AMECO (2015=100)</Data></Cell>
